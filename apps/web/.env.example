# Web app environment — see also ../../.env.example for the full monorepo list.

NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: separate origin for TikTok search (defaults to NEXT_PUBLIC_API_URL)
# NEXT_PUBLIC_TIKTOK_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Experiments (Settings → TikTok provider). Must match API VKARA_EXPERIMENTS when testing TikTok.
# NEXT_PUBLIC_VKARA_EXPERIMENTS=false
# VKARA_EXPERIMENTS=false

# VKARA_AIO=1
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Server-only (route handlers)
# WHISPER_URL=
# HF_TOKEN=
