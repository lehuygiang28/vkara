NODE_ENV=development # production/development

# Public site origin used for YouTube embed playability checks (must match the web app URL)
PUBLIC_APP_URL=http://localhost:3000

# Embed playability (flags: true|false|1|0|yes|no|on|off — unset = default off)
# See packages/env/src/flags.ts (FLAG_DOCS + VKARA_TUNABLE_DOCS)
# VKARA_EMBED_CACHE_TTL_SECONDS=2592000
# VKARA_EMBED_PREFILTER_AT_LIST=false

# Experiments (TikTok search via Playwright). Requires Chromium on the API host.
# VKARA_EXPERIMENTS=false

# Dev/WSL only: disable TLS certificate verification for outbound YouTube HTTPS fetches.
# VKARA_TLS_INSECURE=true

# Playwright forward proxy (optional — TikTok search egress)
# PLAYWRIGHT_PROXY_SERVER=http://127.0.0.1:1080
# PLAYWRIGHT_PROXY_USERNAME=vkara
# PLAYWRIGHT_PROXY_PASSWORD=
# CF_PROXY_TUNNEL_HOSTNAME=vkara-prx.example.giang.io.vn
# CF_PROXY_TUNNEL_LOCAL_URL=127.0.0.1:1080
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Comma-separated browser origins for HTTP CORS + WebSocket Origin checks (unset = allow all).
# Must include the web app origin when API/WS is on a different host (e.g. split deploy).
# CORS_ORIGINS=http://localhost:3000,https://vkara-local.giang.io.vn

PORT=8000

REDIS_HOST='localhost'
REDIS_PORT='6379'
# REDIS_PASSWORD=

# release room after it has no connected clients for this many seconds (default in code: 3600 = 1 hour)
EMPTY_ROOM_TIMEOUT=3600

# Service report cron (default: 0 * * * * = top of each hour). Local test every minute: */1 * * * *
# SERVICE_REPORT_CRON=*/1 * * * *

# write some logs to files
LOG_TO_FILES=false # true/false
ERROR_LOG_PATH=logs/error.log
COMBINED_LOG_PATH=logs/combined.log