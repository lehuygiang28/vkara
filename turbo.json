{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "dist/**", "!.next/cache/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "test": {
            "inputs": ["src/**", "tests/**", "../../vitest.config.mts"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
