{
    "$schema": "https://turborepo.com/schema.json",
    "globalEnv": [
        "NODE_ENV",
        "VKARA_AIO",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_WS_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_GOOGLE_ANALYTICS_ID",
        "NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "dist/**", "!.next/cache/**"]
        },
        "lint": {
            "dependsOn": ["^lint"],
            "inputs": ["$TURBO_DEFAULT$", "../../eslint.config.mjs"]
        },
        "lint:fix": {
            "dependsOn": ["^lint:fix"],
            "cache": false
        },
        "test": {
            "inputs": ["src/**", "tests/**", "../../vitest.config.mts"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
