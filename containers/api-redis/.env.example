PORT=8000

# Required by supervisord (embed playability). On Hugging Face Spaces, entrypoint sets https://${SPACE_HOST} when unset.
PUBLIC_APP_URL=http://localhost:3000

REDIS_HOST='localhost'
REDIS_PORT='6379'
REDIS_PASSWORD='giang'

# Optional: enable TikTok search experiment (needs Chromium + Playwright browsers on the API host)
# VKARA_EXPERIMENTS=1

# --- Playwright forward proxy (TikTok search egress) ---
# Option A: Cloudflare Tunnel TCP (entrypoint starts cloudflared access tcp automatically)
# CF_PROXY_TUNNEL_HOSTNAME=vkara-prx.example.giang.io.vn
# CF_PROXY_TUNNEL_LOCAL_URL=127.0.0.1:1080
# PLAYWRIGHT_PROXY_USERNAME=vkara
# PLAYWRIGHT_PROXY_PASSWORD=
# Optional Zero Trust service token (omit when Access policy is Bypass):
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
#
# When CF_PROXY_TUNNEL_HOSTNAME is set and PLAYWRIGHT_PROXY_SERVER is unset,
# entrypoint defaults PLAYWRIGHT_PROXY_SERVER=http://127.0.0.1:1080
#
# Option B: direct proxy URL (no cloudflared in container)
# PLAYWRIGHT_PROXY_SERVER=http://127.0.0.1:3128
# PLAYWRIGHT_PROXY_USERNAME=vkara
# PLAYWRIGHT_PROXY_PASSWORD=
