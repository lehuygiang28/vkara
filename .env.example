# vkara monorepo — copy to apps/api/.env and apps/web/.env (or symlink) for local dev.
# Do not commit secrets. See packages/env/src/flags.ts (VKARA_ENV_DOCS) for VKARA_* docs.

# --- API (apps/api) ---
NODE_ENV=development
PORT=8000

PUBLIC_APP_URL=http://localhost:3000
# APP_PUBLIC_URL=
# WEB_ORIGIN=

# Embed playability (true|false|1|0|yes|no|on|off — unset = default off)
# VKARA_EMBED_PREFILTER_AT_LIST=false
# VKARA_EMBED_CACHE_TTL_SECONDS=2592000

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

EMPTY_ROOM_TIMEOUT=3600
# SERVICE_REPORT_CRON=0 * * * *

LOG_TO_FILES=false
LOG_LEVEL=info
ERROR_LOG_PATH=logs/error.log
COMBINED_LOG_PATH=logs/combined.log

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# VKARA_AIO=1
# GOOGLE_SITE_VERIFICATION=
# ANALYZE=true

# WHISPER_URL=
# HF_TOKEN=
